    },
    {
      "source": "/cv-interpretability/:path*",
      "destination": "https://explorables-cv-interpretability.vercel.app/cv-interpretability/:path*"
    },
    {
      "source": "/embeddings-playground/:path*",
      "destination": "https://explorables-embeddings-playground.vercel.app/embeddings-playground/:path*"
    },
    {
      "source": "/transformer-playground/:path*",
